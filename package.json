{
	"name": "marianialessandro-monorepo",
	"private": true,
	"version": "0.1.0",
	"type": "module",
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"scripts": {
		"dev": "concurrently -n site,files -c blue,green \"npm run dev:site\" \"npm run dev:files\"",
		"dev:site": "npm run dev --workspace @marianialessandro/marianialessandro.com",
		"dev:files": "npm run dev --workspace @marianialessandro/files.marianialessandro.com",
		"build": "npm run build --workspaces --if-present",
		"build:site": "npm run build --workspace @marianialessandro/marianialessandro.com",
		"build:files": "npm run build --workspace @marianialessandro/files.marianialessandro.com",
		"check": "npm run check --workspaces --if-present",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write ."
	},
	"devDependencies": {
		"@eslint/compat": "^1.2.5",
		"@eslint/js": "^9.18.0",
		"concurrently": "^9.1.2",
		"eslint": "^9.18.0",
		"eslint-config-prettier": "^10.0.1",
		"eslint-plugin-svelte": "^3.0.0",
		"globals": "^16.0.0",
		"prettier": "^3.4.2",
		"prettier-plugin-svelte": "^3.3.3",
		"prettier-plugin-tailwindcss": "^0.6.11",
		"typescript-eslint": "^8.20.0"
	}
}
